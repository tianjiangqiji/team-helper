# Flask
SECRET_KEY=

# 后台管理密码
ADMIN_PASSWORD=

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SSL 验证配置
VERIFY_SSL=True

----------------------------------
以下为可选配置
----------------------------------



# 代理配置（可选，如果需要通过代理访问ChatGPT）
# HTTP_PROXY=http://proxy-server:port
# HTTPS_PROXY=http://proxy-server:port
# SOCKS5_PROXY=socks5://user:pass@proxy-server:port

# 外部链接（可选）
GROUP_URL=
CUSTOMER_SERVICE_URL=

# Cloudflare Turnstile（可选，用于人机验证）
CF_TURNSTILE_SECRET_KEY=
CF_TURNSTILE_SITE_KEY=

# 易支付配置（用于支付功能）
EPAY_MERCHANT_ID=
EPAY_API_KEY=
EPAY_NOTIFY_URL=
EPAY_RETURN_URL=
EPAY_GATEWAY_URL=
EPAY_PRODUCT_PRICE=1.00
PAYMENT_FEE_RATE=0.05

# 订单超时配置（秒）
ORDER_TIMEOUT=1800
ORDER_CLEANUP_INTERVAL=300

# 并发控制
MAX_CONCURRENT_INVITES=3
